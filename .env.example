# Operator 私钥（执行引擎用于发送链上交易）
OPERATOR_PRIVATE_KEY=0x...

# 合约地址（部署后填入）
HIVE_ROUND_ADDRESS=0x...
HIVE_VAULT_ADDRESS=0x...
HIVE_SCORE_ADDRESS=0x...
HIVE_AGENT_ADDRESS=0x...

# Agent 私钥（SDK 示例用）
AGENT_PRIVATE_KEY=0x...

# RPC
RPC_URL=https://mainnet-rpc.axonchain.ai/
WS_URL=wss://mainnet-rpc.axonchain.ai/ws

# 执行模式: dryrun / polymarket / cex
EXECUTION_MODE=dryrun

# ─── Polymarket 金库账号 ───────────────────────────────
# Polygon 链上的 EOA 私钥（用于签名 Polymarket 订单）
# ⚠️ 安全提示：生产环境请使用 AWS KMS / HashiCorp Vault
POLYMARKET_PRIVATE_KEY=0x...
# CLOB API 地址
POLYMARKET_HOST=https://clob.polymarket.com
# Polygon mainnet=137, Amoy testnet=80002
POLYMARKET_CHAIN_ID=137
# 签名类型: 0=EOA, 1=Proxy(Magic钱包), 2=GnosisSafe(浏览器钱包)
POLYMARKET_SIGNATURE_TYPE=0
# 代理钱包地址（仅 signature_type=1 或 2 时填写）
# POLYMARKET_FUNDER=0x...
# 目标币种
POLYMARKET_CRYPTO=BTC
# 预测周期（分钟）
POLYMARKET_INTERVAL=15
# 最大滑点 (basis points, 200 = 2%)
POLYMARKET_MAX_SLIPPAGE=200

# 数据库
DB_PASSWORD=hive_dev

# 监控
GRAFANA_PASSWORD=admin

# LLM Agent（可选）
OPENAI_API_KEY=sk-...
